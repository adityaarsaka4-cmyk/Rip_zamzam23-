// ── CryptoBackend ──────────────────────────────────────────────
const CB=(()=>{
  let _hk=null,_ak=null,_ready=false;
  const b64u=s=>btoa(s).replace(/=/g,"").replace(/\+/g,"-").replace(/\//g,"_");
  const fromb64u=s=>atob(s.replace(/-/g,"+").replace(/_/g,"/")+("==".slice(0,(4-s.length%4)%4)));
  async function init(){
    try{
      const rawArr=Array.from(crypto.getRandomValues(new Uint8Array(32)));
      [_hk,_ak]=await Promise.all([
        crypto.subtle.importKey("raw",new Uint8Array(rawArr),{name:"HMAC",hash:"SHA-256"},false,["sign","verify"]),
        crypto.subtle.generateKey({name:"AES-GCM",length:256},false,["encrypt","decrypt"])
      ]);
      _ready=true;emitAudit({layer:"CB",type:"READY",severity:"OK",msg:"CryptoBackend initialized"});
    }catch(e){emitAudit({layer:"CB",type:"FAIL",severity:"CRITICAL",msg:"Init failed: "+e.message});}
  }
  async function signJWT(payload){
    if(!_ready)await init();
    const jti=Array.from(crypto.getRandomValues(new Uint8Array(8))).map(b=>b.toString(16).padStart(2,"0")).join("");
    const nonce=Array.from(crypto.getRandomValues(new Uint8Array(4))).map(b=>b.toString(16).padStart(2,"0")).join("");
    const h=b64u(JSON.stringify({alg:"HS256",typ:"JWT"}));
    const b=b64u(JSON.stringify({...payload,jti,nonce,iat:Math.floor(Date.now()/1000),exp:Math.floor(Date.now()/1000)+3600}));
    const msg=new TextEncoder().encode(h+"."+b);
    const sig=await crypto.subtle.sign("HMAC",_hk,msg);
    return h+"."+b+"."+b64u(String.fromCharCode(...new Uint8Array(sig)));
  }
  async function verifyJWT(token){
    if(!_ready||!token)return null;
    try{
      const pts=token.split(".");if(pts.length<3)return null;
      const msg=new TextEncoder().encode(pts[0]+"."+pts[1]);
      const sig=Uint8Array.from(fromb64u(pts[2]),c=>c.charCodeAt(0));
      if(!(await crypto.subtle.verify("HMAC",_hk,sig,msg)))return null;
      const p=JSON.parse(fromb64u(pts[1]));
      return Math.floor(Date.now()/1000)<p.exp?p:null;
    }catch(e){return null;}
  }
  async function encryptAES(pt){
    if(!_ready)await init();
    const iv=crypto.getRandomValues(new Uint8Array(12));
    const ct=await crypto.subtle.encrypt({name:"AES-GCM",iv},_ak,new TextEncoder().encode(pt));
    const hex=a=>Array.from(a).map(b=>b.toString(16).padStart(2,"0")).join("");
    return{iv:hex(iv),ct:hex(new Uint8Array(ct))};
  }
  async function decryptAES(enc){
    if(!_ready)return null;
    try{
      const fh=h=>new Uint8Array(h.match(/.{2}/g).map(b=>parseInt(b,16)));
      const plain=await crypto.subtle.decrypt({name:"AES-GCM",iv:fh(enc.iv)},_ak,fh(enc.ct));
      return new TextDecoder().decode(plain);
    }catch(e){return null;}
  }
  return Object.freeze({init,signJWT,verifyJWT,encryptAES,decryptAES,get ready(){return _ready;}});
})();

