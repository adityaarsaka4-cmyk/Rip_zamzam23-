const SESSION={id:Array.from(crypto.getRandomValues(new Uint8Array(8))).map(b=>b.toString(16).padStart(2,"0")).join(""),start:Date.now(),events:0,threats:0};
const AUDIT_BUS={_ls:new Map(),_id:0,log:[],sub(fn){const id=++this._id;this._ls.set(id,fn);return id;},unsub(id){this._ls.delete(id);}};
let _aqFlush=null;const _aq=[];
let _chainState="genesis-"+SESSION.id.slice(0,8);
let _alertFired=false;

function emitAudit(ev){
  const now=new Date();
  const ts=String(now.getHours()).padStart(2,"0")+":"+String(now.getMinutes()).padStart(2,"0")+":"+String(now.getSeconds()).padStart(2,"0")+"."+String(now.getMilliseconds()).padStart(3,"0");
  const e={id:Date.now()+Math.random(),ts,seq:++SESSION.events,...ev};
  if(_aq.length>200)_aq.shift();_aq.push(e);
  if(["HIGH","CRITICAL"].includes(ev.severity))SESSION.threats++;
  if(!_aqFlush){
    const flush=()=>{
      const b=_aq.splice(0);
      if(b.length){
        const allR=[...b,...AUDIT_BUS.log.slice(0,20)];
        const highCnt=allR.filter(e2=>["HIGH","CRITICAL"].includes(e2.severity)).length;
        if(highCnt>=3&&!_alertFired){
          _alertFired=true;setTimeout(()=>{_alertFired=false;},60000);
          const n2=new Date();
          const ts2=`${String(n2.getHours()).padStart(2,"0")}:${String(n2.getMinutes()).padStart(2,"0")}:${String(n2.getSeconds()).padStart(2,"0")}`;
          b.push({id:Date.now()+.5,ts:ts2,seq:++SESSION.events,layer:"ALERT",type:"THRESHOLD",severity:"CRITICAL",msg:"🚨 "+highCnt+" threats in window — mitigation active"});
          SESSION.threats+=5;
        }
        b.forEach(entry=>{
          sha256hex(_chainState+(entry.ts||"")+(entry.type||"")+(entry.msg||"")).then(h=>{_chainState=h;entry.chain=h.slice(0,12);});
        });
        AUDIT_BUS.log=[...b,...AUDIT_BUS.log].slice(0,50);
        b.forEach(entry=>IDB.put(entry));
        AUDIT_BUS._ls.forEach(fn=>{try{fn(AUDIT_BUS.log[0]);}catch(e){}});
      }
      _aqFlush=null;
    };
    _aqFlush=typeof requestIdleCallback!=="undefined"?requestIdleCallback(flush,{timeout:800}):setTimeout(flush,800);
  }
}

// ── IndexedDB Encrypted Audit Store ───────────────────────────
const IDB=(()=>{
  const DB="nexus-audit-v2",ST="logs";
  let _db=null;
  async function open(){
    if(_db)return _db;
    return new Promise((res,rej)=>{
      const req=indexedDB.open(DB,1);
      req.onupgradeneeded=e=>{const db=e.target.result;if(!db.objectStoreNames.contains(ST))db.createObjectStore(ST,{keyPath:"id"});};
      req.onsuccess=e=>{_db=e.target.result;res(_db);};
      req.onerror=()=>rej(req.error);
    });
  }
  async function put(entry){
    try{
      const db=await open();
      const enc=await STOR._enc(entry);
      await new Promise((res,rej)=>{const tx=db.transaction(ST,"readwrite");const r=tx.objectStore(ST).put({id:String(entry.id),data:enc});r.onsuccess=res;r.onerror=rej;});
    }catch(e){}
  }
  async function getAll(){
    try{
      const db=await open();
      const rows=await new Promise((res,rej)=>{const tx=db.transaction(ST,"readonly");const r=tx.objectStore(ST).getAll();r.onsuccess=()=>res(r.result||[]);r.onerror=rej;});
      const dec=await Promise.all(rows.map(r=>STOR._dec(r.data).catch(()=>null)));
      return dec.filter(Boolean).sort((a,b)=>(b.seq||0)-(a.seq||0)).slice(0,300);
    }catch(e){return[];}
  }
  async function count(){try{const db=await open();return new Promise((res,rej)=>{const tx=db.transaction(ST,"readonly");const r=tx.objectStore(ST).count();r.onsuccess=()=>res(r.result);r.onerror=()=>res(0);});}catch(e){return 0;}}
  async function clear(){try{const db=await open();await new Promise((res,rej)=>{const tx=db.transaction(ST,"readwrite");const r=tx.objectStore(ST).clear();r.onsuccess=res;r.onerror=rej;});}catch(e){}}
  return Object.freeze({put,getAll,count,clear});
})();

// ── PBKDF2-AES encrypted STOR ─────────────────────────────────
const _eskCache={};
async function _getEsk(){
  if(_eskCache.k)return _eskCache.k;
  const pw=new TextEncoder().encode("nsk-"+SESSION.id.slice(0,10)+"-"+SESSION.start.toString(36));
  const salt=new TextEncoder().encode("nexus-pbkdf2-salt-v1");
  const base=await crypto.subtle.importKey("raw",pw,{name:"PBKDF2"},false,["deriveKey"]);
  _eskCache.k=await crypto.subtle.deriveKey({name:"PBKDF2",salt,iterations:50000,hash:"SHA-256"},base,{name:"AES-GCM",length:256},false,["encrypt","decrypt"]);
  return _eskCache.k;
}
const STOR={
  async _enc(v){
    try{
      const k=await _getEsk();
      const iv=crypto.getRandomValues(new Uint8Array(12));
      const ct=await crypto.subtle.encrypt({name:"AES-GCM",iv},k,new TextEncoder().encode(JSON.stringify(v)));
      const hex=a=>Array.from(a).map(b=>b.toString(16).padStart(2,"0")).join("");
      return JSON.stringify({_ne:1,iv:hex(iv),ct:hex(new Uint8Array(ct))});
    }catch(e){return JSON.stringify(v);}
  },
  async _dec(raw){
    try{
      const p=JSON.parse(raw);
      if(!p._ne)return JSON.parse(raw);
      const k=await _getEsk();
      const fh=h=>new Uint8Array(h.match(/.{2}/g).map(b=>parseInt(b,16)));
      const plain=await crypto.subtle.decrypt({name:"AES-GCM",iv:fh(p.iv)},k,fh(p.ct));
      return JSON.parse(new TextDecoder().decode(plain));
    }catch(e){return null;}
  },
  async get(k){try{const r=await window.storage.get(k);if(!r)return null;return this._dec(r.value);}catch(e){return null;}},
  async set(k,v){try{const enc=await this._enc(v);await window.storage.set(k,enc);}catch(e){}},
  async del(k){try{await window.storage.delete(k);}catch(e){}}
};

// ── IntegrityGuard ─────────────────────────────────────────────
const IntegrityGuard=(()=>{
  const _snaps=new Map();
  let _running=false,_violations=0,_iid=null;
  const _targets=[];
  async function _hash(fn){
    try{const src=typeof fn==="function"?fn.toString():JSON.stringify(fn);return await sha256hex(src+SESSION.id.slice(0,6));}catch(e){return null;}
  }
  function addTarget(label,getFn){_targets.push([label,getFn]);}
  async function verify(){
    for(const[label,getFn] of _targets){
      try{
        const cur=await _hash(getFn());
        const exp=_snaps.get(label);
        if(!exp||!cur)continue;
        if(cur!==exp){_violations++;emitAudit({layer:"INTEGRITY",type:"TAMPER_DETECTED",severity:"CRITICAL",msg:"["+label+"] hash mismatch — violation #"+_violations});
          if(_violations>=3){emitAudit({layer:"INTEGRITY",type:"LOCKDOWN",severity:"CRITICAL",msg:"3+ violations — integrity lockdown"});stop();}}
      }catch(e){}
    }
  }
  async function start(){
    if(_running)return;_running=true;
    for(const[label,getFn] of _targets){const h=await _hash(getFn());if(h)_snaps.set(label,h);}
    _iid=setInterval(()=>{verify();},8000);
    emitAudit({layer:"INTEGRITY",type:"GUARD_START",severity:"OK",msg:"IntegrityGuard active — "+_targets.length+" targets"});
  }
  function stop(){if(_iid){clearInterval(_iid);_iid=null;_running=false;}}
  return Object.freeze({addTarget,start,stop,getViolations:()=>_violations});
})();

